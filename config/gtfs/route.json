{
  "default_route_id_enabled": true,
  "use_route_short_name_for_route_id": true,
  "route_id_previous_char_configs": [
    {
      "char": "MT",
      "id_part": 28000000
    }
  ],
  "default_route_long_name_enabled": true,
  "direction_finder_enabled": true,
  "allow_non_descriptive_head_signs_until": {
    "14": "20260410",
    "18": "20260410"
  },
  "trip_headsign_cleaners": [
    {
      "regex": "( (am|pm)$)",
      "ignore_case": true
    },
    {
      "regex": "(expresse|express )",
      "ignore_case": true
    }
  ],
  "use_stop_id_for_stop_code": true,
  "stop_id_clean_merged": true,
  "stop_name_cleaners": [
    {
      "regex": "devant",
      "ignore_case": true,
      "is_word": true
    },
    {
      "regex": "((^|\\W)(civique (#)?(\\d+))(\\W|$))",
      "ignore_case": true,
      "replacement": "$2#$5$6"
    }
  ]
}
